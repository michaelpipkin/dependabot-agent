{
  "name": "dependabot-agent",
  "version": "1.0.0",
  "author": "Michael Pipkin <michael.a.pipkin@gmail.com>",
  "description": "On-demand CLI agent that reconciles npm/pnpm dependency overrides with GitHub Dependabot alerts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelpipkin/dependabot-agent.git"
  },
  "bugs": {
    "url": "https://github.com/michaelpipkin/dependabot-agent/issues"
  },
  "homepage": "https://github.com/michaelpipkin/dependabot-agent#readme",
  "type": "module",
  "bin": {
    "dependabot-agent": "dist/index.js"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json && node dist/index.js",
    "test": "tsc -p tsconfig.test.json && cd dist-test && node --test",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "dependabot",
    "overrides",
    "npm",
    "pnpm",
    "security",
    "vulnerabilities",
    "cli"
  ],
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.0"
}